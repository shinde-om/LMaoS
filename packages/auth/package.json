{
  "name": "@workspace/auth",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/auth.mjs",
  "types": "./dist/auth.d.mts",
  "exports": {
    ".": {
      "types": "./dist/auth.d.mts",
      "import": "./dist/auth.mjs",
      "require": "./dist/auth.cjs"
    },
    "./auth-client": {
      "types": "./dist/auth-client.d.mts",
      "import": "./dist/auth-client.mjs",
      "require": "./dist/auth-client.cjs"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "packageManager": "pnpm@10.33.4",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@workspace/db": "workspace:*",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@workspace/typescript-config": "workspace:*",
    "tsdown": "^0.22.4"
  }
}

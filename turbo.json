{
  "$schema": "https://v2-10-5.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL", 
    "BETTER_AUTH_SECRET", 
    "BACKEND_URL", 
    "BACKEND_URL_PORT", 
    "GOOGLE_CLIENT_ID", 
    "GOOGLE_CLIENT_SECRET"
  ], 
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "dependsOn": ["^build","^db:generate"],
      "cache": false,
      "persistent": true
    },
    "db:generate": { 
      "cache": false
    }, 
    "db:migrate": { 
      "cache": false
    }, 
    "db:deploy": { 
      "cache": false
    } 
  }
}
